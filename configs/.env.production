# Production Environment Configuration
# Ensure all sensitive values are set via environment variables in production

# ===================== Flask 配置 =====================
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=${SECRET_KEY}  # Set via CI/CD or deployment platform
PORT=5000

# ===================== LINE Messaging API =====================
LINE_CHANNEL_SECRET=${LINE_CHANNEL_SECRET}
LINE_CHANNEL_ACCESS_TOKEN=${LINE_CHANNEL_ACCESS_TOKEN}

# ===================== Google Gemini API =====================
GEMINI_API_KEY=${GEMINI_API_KEY}
GEMINI_MODEL=gemini-1.5-flash

# ===================== 日誌配置 =====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===================== 應用設置 =====================
DEFAULT_TRANSLATION_MODE=ja
MAX_MESSAGE_LENGTH=5000
